# Core app
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
PUBLIC_DOMAIN="aura-v2-shell-xqs7h463qa-uc.a.run.app"

# Secrets / privileged auth
CRON_SECRET="YOUR_CRON_SECRET"
AURA_ADMIN_SECRET="YOUR_AURA_ADMIN_SECRET"

# Safety toggles (keep disabled by default)
ALLOW_MCP_DEPLOY="false"
ALLOW_KALSHI_TRADING="false"

# Kalshi (optional unless authenticated portfolio operations are needed)
KALSHI_API_KEY_ID=""
KALSHI_PRIVATE_KEY=""

# Optional SEO/API helpers
INDEXNOW_KEY=""

# Optional for local/service-account based Google API usage
GOOGLE_APPLICATION_CREDENTIALS=""

# Optional chat controls
CHAT_RATE_LIMIT="10"
CHAT_PROMPT_CHARS_MAX="4000"
CHAT_HISTORY_ITEMS_MAX="24"
CHAT_IMAGE_B64_CHARS_MAX="2500000"
CHAT_BODY_LIMIT_MB="4"
